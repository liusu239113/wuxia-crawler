storeFile=release/anlao-release.jks
storePassword=请填写正式签名库密码
keyAlias=请填写正式签名别名
keyPassword=请填写正式签名密钥密码
storeType=pkcs12

# GitHub Actions 需要配置以下 Secrets：
# RELEASE_KEYSTORE_BASE64: release/anlao-release.jks 的 base64 内容
# RELEASE_STORE_PASSWORD: storePassword
# RELEASE_KEY_ALIAS: keyAlias
# RELEASE_KEY_PASSWORD: keyPassword
